# Copie este arquivo para ".env" (local) e configure as variaveis na Vercel.
# Pegue esses valores em: Supabase > Project Settings > API
# Sem essas variaveis, o app funciona em modo LOCAL (localStorage), so no seu navegador.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
